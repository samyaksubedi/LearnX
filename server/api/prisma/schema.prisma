generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String @id @default(uuid())
  name         String
  email        String @unique
  passwordHash String

  // Verification 
  isVerified                    Boolean        @default(false)
  emailVerificationToken        String?
  emailVerificationTokenExpires DateTime?
  // Relations
  conversations                 Conversation[]

  // Reset password
  resetPasswordToken        String?
  resetPasswordTokenExpires DateTime?
  // Timestamps
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  userSessions              UserSession[]
}

enum sourceType {
  youtube
  audio
  video
  pdf
}

enum status {
  processing
  ready
  failed
}

model Conversation {
  id             String     @id @default(uuid())
  title          String? // Youtube Video Title | Media Title | Can change later 
  userId         String
  sourceLink     String // Cloudinary uploaded media public link | youtube video link
  sourcePublicId String? // Helps cloudinary to edit the media (update delete ...) - optional cause for youtube we don't have any publicId 
  sourceType     sourceType
  status         status
  errorMessage   String? // If processing failed python will give us the errorMessage and status in the response and we will save it here : ) 
  // timestamps
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt // We Manually Update everytime a new message is added to this conversation 
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       Message[]
}

enum MessageRole {
  User
  Assistant
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  sourceReference  Json? // {start? ,end? , pageNumber?} --> Only for Assistant Messages
  createdAt      DateTime     @default(now())
}

model UserSession {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken        String
  refreshTokenExpires DateTime
  deviceInfo          Json?
  ipAddress           String?
  // timeStamps
  createdAt           DateTime @default(now())
  lastUsedAt          DateTime @updatedAt // Updates every time when user gets a new accessToken 
}
